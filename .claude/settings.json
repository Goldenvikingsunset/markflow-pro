{
  "env": {
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(npm run compile)",
      "Bash(npm run watch)",
      "Bash(npm run package)",
      "Bash(npm run vsix)",
      "Bash(npm test)",
      "Bash(npm install)",
      "Bash(node esbuild.js)",
      "Bash(npx esbuild*)",
      "Bash(npx vsce package)",
      "Bash(node -e \"const p=require\\('./package.json'\\); console.log\\('version:', p.version\\)\")"
    ],
    "deny": [
      "Bash(vsce publish)",
      "Bash(npm publish)",
      "Bash(rm -rf*)",
      "Bash(rmdir /s*)"
    ]
  }
}
